# ── ModelFungible Chat POC ─────────────────────────────────────────────────────
# Copy to .env and fill in your values.

# ── Mode: standalone (no gateway) ─────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsr_your_key_here

# ── Mode: via ModelFungible gateway ───────────────────────────────────────────
# Leave empty to use direct Groq. Fill in to use the full gateway:
#   MF_BASE_URL=http://localhost:8765/api
#   MF_API_KEY=dev-key
MF_BASE_URL=
MF_API_KEY=dev-key

# ── Model ─────────────────────────────────────────────────────────────────────
# For direct Groq: use just the model slug, e.g. llama-3.3-70b-versatile
# For gateway:     use the full name, e.g. groq/llama-3.3-70b-versatile
MF_MODEL=llama-3.3-70b-versatile

# ── Routing ──────────────────────────────────────────────────────────────────
# Only used when going via gateway (MF_BASE_URL is set)
MF_MODE=balanced   # fastest | cheapest | balanced

# ── Guardrails ───────────────────────────────────────────────────────────────
MF_GUARDRAIL=     # comma-separated terms to filter from output
MF_MAX_LEN=4000   # max output chars (0 = unlimited)

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET=change-me-to-something-random
