# ── ModelFungible Chat POC ──────────────────────────────────────────────────────
# Copy to .env and fill in your values

# ── Gateway ────────────────────────────────────────────────────────────────────
# URL of the ModelFungible Admin Gateway (from enterprise/admin_app.py)
# If running the gateway locally on port 8765, use http://localhost:8765/api
# Leave empty to use Groq directly (requires GROQ_API_KEY below)
MF_BASE_URL=http://localhost:8765/api

# API key for the gateway (any string for dev)
MF_API_KEY=dev-key

# Default model when none selected (Groq free tier)
MF_MODEL=groq/llama-3.3-70b-versatile

# Routing mode: fastest | cheapest | balanced
MF_MODE=balanced

# ── Guardrails ─────────────────────────────────────────────────────────────────
# Comma-separated terms to block from model output
# MF_GUARDRAIL=confidential,secret,do not share,classified
MF_GUARDRAIL=

# Max output characters (0 = unlimited)
MF_MAX_LEN=4000

# ── Direct model API keys (fallback if MF_BASE_URL not set) ───────────────────
GROQ_API_KEY=gsr_
OPENAI_API_KEY=sk-
ANTHROPIC_API_KEY=sk-ant-

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET=change-me-to-something-random
